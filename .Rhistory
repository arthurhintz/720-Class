library(tidyverse)
library(readxl)
library(sf)
library(lme4)
library(factoextra)
library(ibd)
library(gstat)
library(sp)
library(anticlust)
library(agricolae)
library(simr)
library(cmdstanr)
library(pbapply)
library(posterior)
data <- read_csv("projeto_data.csv")
EC_mat <- data |>
filter(row_id <=15) |>
select(row_id, ew_group, ec_mean) |>
pivot_wider(
names_from = ew_group,
values_from = ec_mean
) |>
arrange(row_id) |>
select(-row_id) |>
as.matrix()
geodados <- as.geodata(EC_mat)
View(geodados)
plot(geodados)
hmax <- summary(geodados)[[3]][[2]]*0.8
hmax
variog(geodados,max.dist = hmax)
vario <- variog(geodados,max.dist = hmax)
gau <- variofit(vario, cov.model = "gau")
plot(vario)
lines(gau)
plot(vario) +
lines(gau)
gau
